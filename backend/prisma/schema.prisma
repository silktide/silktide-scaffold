// Prisma Schema — single source of truth for the database.
//
// To customize:
//   1. Add your models below.
//   2. Run `pnpm --filter backend db:generate` to regenerate the client.
//   3. Run `pnpm db:migrate` to create and apply a migration.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
